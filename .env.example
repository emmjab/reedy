# Database (Neon or Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/reedy?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="your-secret-here"

# OAuth providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# External APIs
GOOGLE_BOOKS_API_KEY=""   # Optional — used as fallback for book metadata

# Cron security
CRON_SECRET="random-secret-for-cron-routes"

# App URL
NEXTAUTH_URL="http://localhost:3000"
