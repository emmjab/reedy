# Database — use the POOLED connection string from Neon, add pgbouncer=true
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct (unpooled) connection — used only by Prisma CLI (db push / migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="your-secret-here"

# OAuth providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# External APIs
GOOGLE_BOOKS_API_KEY=""   # Optional — used as fallback for book metadata

# Cron security
CRON_SECRET="random-secret-for-cron-routes"

# App URL
NEXTAUTH_URL="http://localhost:3000"
